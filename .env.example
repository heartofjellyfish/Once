# Once — environment variables
# Copy this file to `.env.local` and fill in the values.

# Postgres. Use any of these — code tries DATABASE_URL first, then the
# auto-injected Vercel Postgres names. If all are unset, the app falls
# back to data/stories.json (dev mode) and the admin area is locked.
DATABASE_URL=
# POSTGRES_URL=              # auto-set by Vercel Postgres integration
# POSTGRES_URL_NON_POOLING=  # used by migrations to avoid pool issues

# OpenAI API key. Required only for /admin/ingest (AI curation).
# /admin/compose works without it.
OPENAI_API_KEY=

# Admin HTTP Basic auth. If either is unset, /admin returns 401.
ADMIN_USER=
ADMIN_PASSWORD=

# Weekly AI spend ceiling, in USD. Hard cutoff — ingest refuses once
# the rolling 7-day sum would exceed this. Default: 0.50
AI_BUDGET_USD_PER_WEEK=0.50

# ── Daily digest email (via Resend) ─────────────────────────────
# If unset, /api/cron/digest is a no-op (logs "skipped"). Resend
# needs qi.land's DNS verified before the first send succeeds.
RESEND_API_KEY=
DIGEST_TO=liuqi627@gmail.com
DIGEST_FROM=Once <noreply@qi.land>
DIGEST_MIN_PENDING=10

# Used in email links (magic review URL).
SITE_ORIGIN=https://once.qi.land

# Protects cron endpoints — Vercel Cron sends this as Bearer header.
CRON_SECRET=

# ── Model overrides (optional) ──────────────────────────────────
# rewrite is what users actually read; default gpt-4o. Prefilter and
# scoring default to gpt-4o-mini (high volume, less at stake).
# REWRITE_MODEL=gpt-4o
# INGEST_PREFILTER_MODEL=gpt-4o-mini
# INGEST_FULL_MODEL=gpt-4o-mini
